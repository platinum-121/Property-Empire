# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local virtual environments
.venv/
venv/
env/

# Build and packaging output
build/
dist/
*.egg-info/

# Local saves and generated runtime data
saves/

# Editor and OS files
.idea/
.vscode/
*.swp
Thumbs.db
.DS_Store
